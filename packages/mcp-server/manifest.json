{
  "dxt_version": "0.2",
  "name": "anyformat-mcp",
  "version": "0.8.0",
  "description": "The official MCP Server for the Anyformat API",
  "author": {
    "name": "Anyformat",
    "email": "support@anyformat.ai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anyformat-ai/anyformat-node.git"
  },
  "homepage": "https://github.com/anyformat-ai/anyformat-node/tree/main/packages/mcp-server#readme",
  "documentation": "https://docs.anyformat.ai",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/index.js"
      ],
      "env": {
        "ANYFORMAT_API_KEY": "${user_config.ANYFORMAT_API_KEY}"
      }
    }
  },
  "user_config": {
    "ANYFORMAT_API_KEY": {
      "title": "api_key",
      "description": "",
      "required": false,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": [
    "api"
  ]
}
